# ─────────────────────────────────────────────────────────────
# Доставки Хубенов — frontend env (Vite). NEVER put secrets here.
# Only the anon (public) key belongs client-side; RLS protects data.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-anon-key-from-`supabase status`

# Public brand / contact (safe to expose)
VITE_COMPANY_PHONE=07895 909915
VITE_COMPANY_ADDRESS=542 Liverpool Road, Eccles, Manchester, M30 7JA

# ─────────────────────────────────────────────────────────────
# Server-side only — set as Supabase Edge Function secrets, NOT here.
# `supabase secrets set ECONT_USER=... ECONT_PASS=...`
